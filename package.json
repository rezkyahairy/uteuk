{
  "name": "uteuk",
  "version": "0.1.2",
  "description": "AI-assisted Second Brain CLI — install and manage Uteuk in your Obsidian vault",
  "main": "dist/cli.js",
  "bin": {
    "uteuk": "./bin/uteuk"
  },
  "type": "module",
  "files": [
    "dist",
    ".uteuk",
    "templates",
    "AGENT.md",
    "CLAUDE.md",
    "QWEN.md",
    "OPENCLAW.md",
    "logo.png"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rezkyahairy/uteuk.git"
  },
  "keywords": [
    "obsidian",
    "second-brain",
    "knowledge-management",
    "para",
    "cli"
  ],
  "author": "Rezky Ahairy",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/rezkyahairy/uteuk/issues"
  },
  "homepage": "https://github.com/rezkyahairy/uteuk#readme",
  "dependencies": {
    "chalk": "^5.6.0",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "memfs": "^4.57.0",
    "prettier": "^3.8.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
